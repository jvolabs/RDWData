MONGODB_URI_DIRECT=
MONGODB_DB_NAME=plateintel
MONGO_DNS_SERVERS=8.8.8.8,8.8.4.4

# RDW Open Data
RDW_BASE_URL=https://opendata.rdw.nl/resource

# Optional: Redis cache (Phase 2)
REDIS_URL=redis://localhost:6379
